# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3:14b
OLLAMA_PREFERRED_MODELS=qwen3:14b,qwen3:32b
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3
OLLAMA_RETRY_DELAY=2.0

# Database (absolute path recommended; relative paths resolve from CWD)
# DB_PATH=/absolute/path/to/interview_prep.db
# Leave commented to use default: project/data/interview_prep.db

# Interview thresholds
QUESTIONS_PER_SESSION=10
SCORE_INCREASE_THRESHOLD=7.0
SCORE_DECREASE_THRESHOLD=4.0

# App
DEBUG=false
LOG_LEVEL=INFO
